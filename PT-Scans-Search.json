            "api.mangaflix.net",
            "mangaflix.net",
            "*.mangaflix.net",
            "mangalivre.to",
            "*.mangalivre.to",
            "hiper.cool",
            "*.hiper.cool",
            "tiamanhwa.com",
            "*.tiamanhwa.com",
            "mangafire.to",
            "*.mangafire.to",
            "graphql.anilist.co",
            "anilist.co",
            "*.anilist.co"
          ],
          "reasoning": "Needed to fetch provider data, chapter pages from supported sources, and AniList OAuth authentication."
        }
      }
    }
  },
  "isDevelopment": false
}
