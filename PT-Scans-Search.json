{
  "id": "PTScansSearch",
  "name": "PT Scans Search",
  "version": "1.1.0",
  "manifestURI": "https://raw.githubusercontent.com/SKRAPT/PT-Scans-Search-Tests/refs/heads/main/PT-Scans-Search.json",
  "language": "javascript",
  "type": "plugin",
  "description": "PT Scans Search com biblioteca AniList",
  "author": "Skrapt",
  "icon": "https://raw.githubusercontent.com/SKRAPT/PT-Scans/main/upscan.png",
  "lang": "pt",
  "payloadURI": "https://raw.githubusercontent.com/SKRAPT/PT-Scans-Search-Tests/refs/heads/main/PT-Scans-Search-2.js",
